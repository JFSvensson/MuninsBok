# Docker-compose environment — copy to .env.docker and fill in values
POSTGRES_USER=muninsbok
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=muninsbok

# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME

# Swagger UI in production — keep disabled unless explicitly needed
# ENABLE_DOCS=false

# Prometheus metrics in production — set bearer token to expose /metrics
# METRICS_TOKEN=CHANGE_ME

# Bank webhook signature verification
# BANK_WEBHOOK_HMAC_SECRET=CHANGE_ME_LONG_RANDOM_SECRET
# BANK_WEBHOOK_SANDBOX_HMAC_SECRET=CHANGE_ME_PROVIDER_SECRET

# Backend org-scoped banking feature gate
# Empty/unset = all orgs, * = all orgs, comma-separated IDs = pilot
BANK_ENABLED_ORG_IDS=

# Exact allowlist for bank OAuth callback URLs (comma-separated)
# BANK_OAUTH_REDIRECT_URI_ALLOWLIST=https://bok.example.se/bank/callback

# Runtime operational flags
# OCR_ENABLE_PDF=false
# DB_MIGRATION_MODE=deploy

# GHCR image source for production override (docker-compose.prod.yml)
# IMAGE_NAMESPACE defaults to repository owner in lowercase (e.g. jfsvensson)
# IMAGE_TAG can be set to a release tag like v0.2.0; default is latest
# IMAGE_NAMESPACE=jfsvensson
# IMAGE_TAG=latest

# Optional backup sidecar (enable with install script flag --with-backup)
# BACKUP_INTERVAL_MINUTES=60
# BACKUP_RETENTION_DAYS=35
# BACKUP_INCLUDE_UPLOADS=true
# BACKUP_INCLUDE_WAL_ARCHIVE=true
# BACKUP_S3_BASE_PREFIX=base

# PostgreSQL WAL archiving settings (foundation for PITR)
# POSTGRES_ARCHIVE_MODE=on
# POSTGRES_ARCHIVE_TIMEOUT_SECONDS=300
# WAL_ARCHIVE_MAX_AGE_MINUTES=120
# WAL_ARCHIVE_MIN_FILES=1

# Restore-to-timepoint helper
# PITR_FORCE_OVERWRITE=false

# Optional external backup upload target (AWS S3 URI)
# Example: BACKUP_S3_URI=s3://my-muninsbok-backups
# BACKUP_S3_URI=
# BACKUP_S3_UPLOADS_PREFIX=uploads
# BACKUP_S3_WAL_PREFIX=wal-archive

# Optional AWS credentials for backup upload
# AWS_REGION=eu-north-1
# AWS_ACCESS_KEY_ID=CHANGE_ME
# AWS_SECRET_ACCESS_KEY=CHANGE_ME
